import 'package:flutter/material.dart';
import 'package:sensors_plus/sensors_plus.dart';

void main() {
  runApp(MyApp());
}

class MyApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      home: AntiGravityPage(),
      debugShowCheckedModeBanner: false,
    );
  }
}

class AntiGravityPage extends StatefulWidget {
  @override
  _AntiGravityPageState createState() => _AntiGravityPageState();
}

class _AntiGravityPageState extends State<AntiGravityPage> {
  double x = 0;
  double y = 0;

  @override
  void initState() {
    super.initState();

    accelerometerEvents.listen((event) {
      setState(() {
        // Reverse gravity effect (antigravity feel)
        x += event.x * -2;
        y += event.y * 2;
      });
    });
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: Text("Antigravity Demo")),
      body: Stack(
        children: [
          Positioned(
            left: MediaQuery.of(context).size.width / 2 + x,
            top: MediaQuery.of(context).size.height / 2 + y,
            child: Container(
              width: 50,
              height: 50,
              decoration: BoxDecoration(
                color: Colors.blue,
                shape: BoxShape.circle,
              ),
            ),
          ),
        ],
      ),
    );
  }
}
